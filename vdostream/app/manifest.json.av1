{
    "schemaVersion": "2.0.0",
    "resources": {
        "linux": {
            "user": {
                "groups": ["video"]
            }
        }
    },
    "acapPackageConf": {
        "setup": {
            "friendlyName": "vdoencodeclient_av1",
            "appName": "vdoencodeclient",
            "vendor": "Axis Communications",
            "vendorId": "1234567890",
            "runOptions": "--format av1 --frames 25",
            "runMode": "never",
            "version": "1.0.0",
            "compatibleOsVersions": [
                {
                    "max": "13"
                }
            ]
        }
    }
}
