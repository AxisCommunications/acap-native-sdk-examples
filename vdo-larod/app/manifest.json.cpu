{
    "schemaVersion": "2.0.0",
    "resources": {
        "linux": {
            "user": {
                "groups": ["video"]
            }
        }
    },
    "acapPackageConf": {
        "setup": {
            "friendlyName": "vdo_larod_cpu",
            "appName": "vdo_larod",
            "vendor": "Axis Communications",
            "vendorId": "1234567890",
            "runOptions": "cpu-tflite /usr/local/packages/vdo_larod/model/model.tflite scale",
            "vendorUrl": "https://www.axis.com",
            "runMode": "never",
            "version": "1.0.0",
            "compatibleOsVersions": [
                {
                    "max": "13"
                }
            ]
        }
    }
}
